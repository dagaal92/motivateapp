generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EstadoPedido {
  PENDIENTE
  CONFIRMADO
  EN_CAMINO
  ENTREGADO
  CANCELADO
  DEVUELTO
}

enum TipoMovimiento {
  INGRESO
  EGRESO
}

enum EstadoDeuda {
  ACTIVA
  PAGADA
}

model Cuenta {
  id           String       @id @default(cuid())
  nombre       String       @unique
  saldo        Int          @default(0)
  creadoEn     DateTime     @default(now())
  movimientos  Movimiento[]
  pedidosFlete Pedido[]     @relation("PedidoCuentaFlete")
  deudas       Deuda[]
  pagosDeuda   PagoDeuda[]
}

model Movimiento {
  id          String         @id @default(cuid())
  cuentaId    String
  cuenta      Cuenta         @relation(fields: [cuentaId], references: [id])
  tipo        TipoMovimiento
  monto       Int
  descripcion String?
  categoria   String?
  creadoEn    DateTime       @default(now())
  pagoDeuda   PagoDeuda?

  @@index([cuentaId])
  @@index([categoria])
}

model Deuda {
  id             String      @id @default(cuid())
  nombre         String
  entidad        String?
  montoTotal     Int
  saldoPendiente Int
  cuotaMensual   Int?
  diaPago        Int
  cuentaId       String?
  cuenta         Cuenta?     @relation(fields: [cuentaId], references: [id])
  estado         EstadoDeuda @default(ACTIVA)
  notas          String?
  creadoEn       DateTime    @default(now())
  actualizadoEn  DateTime    @updatedAt
  pagos          PagoDeuda[]

  @@index([estado])
  @@index([cuentaId])
}

model PagoDeuda {
  id           String      @id @default(cuid())
  deudaId      String
  deuda        Deuda       @relation(fields: [deudaId], references: [id], onDelete: Cascade)
  cuentaId     String
  cuenta       Cuenta      @relation(fields: [cuentaId], references: [id])
  movimientoId String?     @unique
  movimiento   Movimiento? @relation(fields: [movimientoId], references: [id])
  monto        Int
  fecha        DateTime    @default(now())

  @@index([deudaId])
  @@index([cuentaId])
}

model Presupuesto {
  id            String         @id @default(cuid())
  categoria     String
  tipo          TipoMovimiento
  anio          Int
  mes           Int
  monto         Int            @default(0)
  creadoEn      DateTime       @default(now())
  actualizadoEn DateTime       @updatedAt

  @@unique([categoria, tipo, anio, mes])
  @@index([anio, mes])
}

model Pedido {
  id             String       @id @default(cuid())
  numeroOrden    String?
  cliente        String?
  telefono       String
  direccion      String?
  ciudad         String?
  producto       String?
  cantidad       Int?
  valorTotal     Int          @default(0)
  estado         EstadoPedido @default(PENDIENTE)
  origen         String       @default("MANUAL")
  shopifyOrderId String?      @unique

  prioridad      String?
  general        String?
  numeroGuia     String?
  transportadora String?
  envio          String?
  ingresoDinero  String?
  departamento   String?
  municipio      String?

  cuentaFleteId  String?
  cuentaFlete    Cuenta?      @relation("PedidoCuentaFlete", fields: [cuentaFleteId], references: [id])

  completadoEn   DateTime?
  impreso        Boolean      @default(false)

  notas          String?
  creadoEn       DateTime     @default(now())
  actualizadoEn  DateTime     @updatedAt

  productos      ProductoPedido[]
  fletes         FletePedido[]

  @@index([estado])
  @@index([creadoEn])
  @@index([cuentaFleteId])
  @@index([general])
  @@index([completadoEn])
}

model ProductoPedido {
  id         String    @id @default(cuid())
  pedidoId   String
  pedido     Pedido    @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  color      String?
  referencia String?
  cantidad   Int       @default(1)
  productoId String?
  producto   Producto? @relation(fields: [productoId], references: [id], onDelete: SetNull)
  creadoEn   DateTime  @default(now())

  @@index([pedidoId])
  @@index([productoId])
}

model Producto {
  id               String   @id @default(cuid())
  shopifyProductId String?
  shopifyVariantId String?  @unique
  nombre           String
  variante         String?
  stock            Int      @default(0)
  activo           Boolean  @default(true)
  creadoEn         DateTime @default(now())
  actualizadoEn    DateTime @updatedAt
  lineas           ProductoPedido[]

  @@index([nombre])
}

model FletePedido {
  id          String   @id @default(cuid())
  pedidoId    String
  pedido      Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  valor       Int      @default(0)
  observacion String?
  creadoEn    DateTime @default(now())

  @@index([pedidoId])
}

model Cliente {
  id            String   @id @default(cuid())
  telefono      String   @unique
  nombre        String?
  email         String?
  ciudad        String?
  departamento  String?
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
}

model OpcionMaestra {
  id       String   @id @default(cuid())
  categoria String
  valor    String
  creadoEn DateTime @default(now())

  @@unique([categoria, valor])
  @@index([categoria])
}
