# Pega aquí tu connection string de Neon
# La encuentras en el dashboard de Neon > tu proyecto > Connection Details
DATABASE_URL="postgresql://usuario:password@ep-xxxx.neon.tech/nombre_db?sslmode=require"

# Shopify: Configuración > Apps y canales de venta > Desarrollar apps > tu app > API credentials
SHOPIFY_STORE_DOMAIN="tu-tienda.myshopify.com"
SHOPIFY_ADMIN_API_TOKEN="shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# "API secret key" / "Client secret" de la misma app (se usa para verificar los webhooks)
SHOPIFY_API_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
